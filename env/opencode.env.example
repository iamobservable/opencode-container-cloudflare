# OpenCode Configuration
# Copy this file to opencode.env and fill in your values

# Ollama Cloud API Key (for using cloud models)
# Get your API key from: https://ollama.com/settings/keys
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-api-key-here

# Default model configuration
# Using glm-5:cloud for Ollama Cloud hosted model
# See available models: https://ollama.com/library
OPENCODE_MODEL=glm-5:cloud

# OpenCode server configuration (optional)
# OPENCODE_SERVER_PORT=4000
# OPENCODE_SERVER_HOSTNAME=0.0.0.0