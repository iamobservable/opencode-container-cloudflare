# Cloudflare Setup Configuration
# Copy this file to cloudflare-setup.env and fill in your values
# This is used for the one-time tunnel provisioning script

# Cloudflare API Token (scoped, preferred over Global API Key)
# Create a token with permissions: Zone.DNS (Edit), Account.Zero Trust (Edit)
# Go to: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# Cloudflare Account ID
# Find it at: https://dash.cloudflare.com/ (right sidebar)
CLOUDFLARE_ACCOUNT_ID=your-account-id-here

# Zone ID for your domain
# Find it at: https://dash.cloudflare.com/ -> select your domain (right sidebar)
CLOUDFLARE_ZONE_ID=your-zone-id-here

# Your domain name (must already exist in Cloudflare)
CLOUDFLARE_DOMAIN=example.com

# Desired subdomain for OpenCode (will create opencode.example.com)
OPENCODE_SUBDOMAIN=opencode

# Tunnel name (identifies your tunnel in Cloudflare)
CLOUDFLARE_TUNNEL_NAME=opencode-tunnel

# Allowed email addresses for Cloudflare Access (One-time PIN authentication)
# Comma-separated list of email addresses
CLOUDFLARE_ALLOWED_EMAILS=user@example.com

# Cloudflare Account email (optional, for Access policies)
# CLOUDFLARE_ACCOUNT_EMAIL=your-email@example.com